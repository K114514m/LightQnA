# Neo4j
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=20021205

# LLM provider: ollama | openai_compatible
LLM_PROVIDER=openai_compatible
LLM_API_BASE=https://api.openai.com/v1
# Full chat-completions endpoints are also accepted, for example:
# LLM_API_BASE=https://aihubmix.com/v1/chat/completions
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2
LLM_TOP_P=1.0
# 0 means provider default
LLM_MAX_TOKENS=0
# Enable only if your provider supports OpenAI response_format={"type":"json_object"}.
LLM_RESPONSE_FORMAT_JSON=false

# Keep local Ollama embedding unless you rebuild the LightRAG index with another embedding model.
LIGHTRAG_EMBEDDING_MODEL=bge-m3:latest
LIGHTRAG_EMBEDDING_DIM=1024
